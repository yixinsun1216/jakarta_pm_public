	pages = {4432},
	file = {Rentschler and Leonova - 2023 - Global air pollution exposure and poverty.pdf:/Users/yixinsun1/Zotero/storage/UVREBGEM/Rentschler and Leonova - 2023 - Global air pollution exposure and poverty.pdf:application/pdf},
}

@article{murray_global_2020,
