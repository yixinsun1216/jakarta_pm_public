@article {Ferdous444,
	author = {Ferdous, Tarana and Siddiqi, Kamran and Semple, Sean and Fairhurst, Caroline and Dobson, Ruaraidh and Mdege, Noreen and Marshall, Anna-Marie and Abdullah, S M and Huque, Rumana},
	title = {Smoking behaviours and indoor air quality: a comparative analysis of smoking-permitted versus smoke-free homes in Dhaka, Bangladesh},
	volume = {31},
	number = {3},
	pages = {444--451},
	year = {2022},
	doi = {10.1136/tobaccocontrol-2020-055969},
	publisher = {BMJ Publishing Group Ltd},
	abstract = {Introduction Exposure to secondhand smoke (SHS) is a health risk to non-smokers. Indoor particulate matter (PM2.5) is associated with SHS exposure and is used as a proxy measure. However, PM2.5 is non-specific and influenced by a number of environmental factors, which are subject to geographical variation. The nature of association between SHS exposure and indoor PM2.5{\textemdash}studied primarily in high-income countries (HICs) context{\textemdash}may not be globally applicable. We set out to explore this association in a low/middle-income country setting, Dhaka, Bangladesh.Methods A cross-sectional study was conducted among households with at least one resident smoker. We inquired whether smoking was permitted inside the home (smoking-permitted homes, SPH) or not (smoke-free homes, SFH), and measured indoor PM2.5 concentrations using a low-cost instrument (Dylos DC1700) for at least 22 hours. We describe and compare SPH and SFH and use multiple linear regression to evaluate which variables are associated with PM2.5 level among all households.Results We surveyed 1746 households between April and August 2018; 967 (55\%) were SPH and 779 (45\%) were SFH. The difference between PM2.5 values for SFH (median 27 {\textmu}g/m3, IQR 25) and SPH (median 32 {\textmu}g/m3, IQR 31) was 5 {\textmu}g/m3 (p\&lt;0.001). Lead participant{\textquoteright}s education level, being a non-smoker, having outdoor space and smoke-free rule at home and not using kerosene oil for cooking were significantly associated with lower PM2.5.Conclusions We found a small but significant difference between PM2.5 concentrations in SPH compared with SFH in Dhaka, Bangladesh{\textemdash}a value much lower than observed in HICs.Data are available upon reasonable request. The data used in this study are the baseline data of a cluster randomised controlled trial (cRCT) study. The protocol manuscript link is given below https://trialsjournal.biomedcentral.com/articles/10.1186/s13063-018-3100-y. The final analysis of the post-intervention data is ongoing. Data could be made available upon reasonable request after completion of all intended publication of this trial. It would be best to contact the trial chief PI (Siddiqi, Kamran, email: kamran.siddiqi@york.ac.ukORCiD ID: 0000-0003-1529-7778) for further queries.},
	issn = {0964-4563},
	URL = {https://tobaccocontrol.bmj.com/content/31/3/444},
	eprint = {https://tobaccocontrol.bmj.com/content/31/3/444.full.pdf},
	journal = {Tobacco Control}
}


